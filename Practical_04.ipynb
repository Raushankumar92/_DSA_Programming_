   "source": [
    "# One-dimensional array (using list)\n",
    "\n",
    "arr = []\n",
    "\n",
    "n = int(input(\"Enter number of elements: \"))\n",
    "\n",
    "for i in range(n):\n",
    "    element = int(input(\"Enter element: \"))\n",
    "    arr.append(element)\n",
    "\n",
    "print(\"Array elements are:\")\n",
    "\n",
    "for i in range(len(arr)):\n",
    "    print(\"Index\", i, \"=\", arr[i])"
   ]
  }
